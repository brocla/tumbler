{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Tumbler",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-confirm",
    { "identifier": "fs:allow-read-file", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-write-file", "allow": [{ "path": "**" }] },
    "fs:allow-read-dir",
    "fs:allow-exists",
    "shell:allow-open"
  ]
}
